{
  "name": "glp-ram",
  "description": "Take over tab memory management: defer loading, pause/unload idle tabs, and relay notifications through a single service worker.",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "icons": "node scripts/gen-icons.mjs",
    "build": "wxt build -b chrome",
    "crx": "wxt build -b chrome && node scripts/pack-crx.mjs",
    "zip": "wxt zip -b chrome",
    "postinstall": "wxt prepare",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "crx3": "^2.0.0",
    "typescript": "^5.7.0",
    "wxt": "^0.20.0"
  }
}
